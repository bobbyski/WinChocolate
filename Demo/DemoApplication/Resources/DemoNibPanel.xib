<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.Cocoa.XIB" version="3.0" toolsVersion="22505" targetRuntime="MacOSX.Cocoa" propertyAccessControl="none" useAutolayout="YES">
    <dependencies>
        <deployment identifier="macosx"/>
        <plugIn identifier="com.apple.InterfaceBuilder.CocoaPlugin" version="22505"/>
    </dependencies>
    <objects>
        <customObject id="-2" userLabel="File's Owner" customClass="DemoNibPanelController">
            <connections>
                <outlet property="nameField" destination="fld-1" id="out-1"/>
                <outlet property="check" destination="chk-1" id="out-2"/>
                <outlet property="slider" destination="sld-1" id="out-3"/>
                <outlet property="popup" destination="pop-1" id="out-4"/>
                <outlet property="countLabel" destination="cnt-1" id="out-5"/>
            </connections>
        </customObject>
        <customObject id="-1" userLabel="First Responder" customClass="FirstResponder"/>
        <customObject id="-3" userLabel="Application" customClass="NSObject"/>
        <customView id="pnl-root-1" identifier="nibPanelRoot">
            <rect key="frame" x="0.0" y="0.0" width="480" height="240"/>
            <autoresizingMask key="autoresizingMask"/>
            <subviews>
                <textField fixedFrame="YES" translatesAutoresizingMaskIntoConstraints="NO" id="ttl-1" identifier="nibTitleLabel">
                    <rect key="frame" x="18" y="202" width="340" height="20"/>
                    <autoresizingMask key="autoresizingMask" flexibleMinY="YES"/>
                    <textFieldCell key="cell" lineBreakMode="clipping" title="Loaded from DemoNibPanel.xib" id="ttl-1c">
                        <font key="font" metaFont="systemBold"/>
                        <color key="textColor" name="labelColor" catalog="System" colorSpace="catalog"/>
                    </textFieldCell>
                </textField>
                <textField fixedFrame="YES" translatesAutoresizingMaskIntoConstraints="NO" id="fld-1" identifier="nibField">
                    <rect key="frame" x="18" y="162" width="220" height="24"/>
                    <autoresizingMask key="autoresizingMask" flexibleMinY="YES"/>
                    <textFieldCell key="cell" scrollable="YES" lineBreakMode="clipping" selectable="YES" editable="YES" sendsActionOnEndEditing="YES" state="on" borderStyle="bezel" drawsBackground="YES" placeholderString="Type here&#8230;" id="fld-1c">
                        <font key="font" metaFont="system"/>
                    </textFieldCell>
                </textField>
                <button verticalHuggingPriority="750" fixedFrame="YES" translatesAutoresizingMaskIntoConstraints="NO" id="btn-1" identifier="nibButton">
                    <rect key="frame" x="252" y="158" width="120" height="32"/>
                    <autoresizingMask key="autoresizingMask" flexibleMinY="YES"/>
                    <buttonCell key="cell" type="push" title="Increment" bezelStyle="rounded" alignment="center" borderStyle="border" imageScaling="proportionallyDown" inset="2" id="btn-1c">
                        <behavior key="behavior" pushIn="YES" lightByBackground="YES" lightByGray="YES"/>
                        <font key="font" metaFont="system"/>
                    </buttonCell>
                    <connections>
                        <action selector="increment:" target="-2" id="act-1"/>
                    </connections>
                </button>
                <textField fixedFrame="YES" translatesAutoresizingMaskIntoConstraints="NO" id="cnt-1" identifier="nibCountLabel">
                    <rect key="frame" x="384" y="164" width="80" height="20"/>
                    <autoresizingMask key="autoresizingMask" flexibleMinY="YES"/>
                    <textFieldCell key="cell" lineBreakMode="clipping" title="0" id="cnt-1c">
                        <font key="font" metaFont="system"/>
                    </textFieldCell>
                </textField>
                <button fixedFrame="YES" translatesAutoresizingMaskIntoConstraints="NO" id="chk-1" identifier="nibCheck">
                    <rect key="frame" x="18" y="120" width="140" height="24"/>
                    <autoresizingMask key="autoresizingMask" flexibleMinY="YES"/>
                    <buttonCell key="cell" type="check" title="Nib checkbox" bezelStyle="regularSquare" imagePosition="left" state="on" inset="2" id="chk-1c">
                        <behavior key="behavior" changeContents="YES" doesNotDimImage="YES" lightByContents="YES"/>
                        <font key="font" metaFont="system"/>
                    </buttonCell>
                </button>
                <button verticalHuggingPriority="750" fixedFrame="YES" translatesAutoresizingMaskIntoConstraints="NO" id="btn-2" identifier="nibShowButton">
                    <rect key="frame" x="296" y="116" width="150" height="32"/>
                    <autoresizingMask key="autoresizingMask" flexibleMinY="YES"/>
                    <buttonCell key="cell" type="push" title="Show Outlet Values" bezelStyle="rounded" alignment="center" borderStyle="border" inset="2" id="btn-2c">
                        <behavior key="behavior" pushIn="YES" lightByBackground="YES" lightByGray="YES"/>
                        <font key="font" metaFont="system"/>
                    </buttonCell>
                    <connections>
                        <action selector="showValues:" target="-2" id="act-2"/>
                    </connections>
                </button>
                <slider fixedFrame="YES" translatesAutoresizingMaskIntoConstraints="NO" id="sld-1" identifier="nibSlider">
                    <rect key="frame" x="18" y="78" width="260" height="26"/>
                    <autoresizingMask key="autoresizingMask" flexibleMinY="YES"/>
                    <sliderCell key="cell" continuous="YES" alignment="left" minValue="0.0" maxValue="100" doubleValue="35" tickMarkPosition="below" sliderType="linear" id="sld-1c"/>
                </slider>
                <popUpButton fixedFrame="YES" translatesAutoresizingMaskIntoConstraints="NO" id="pop-1" identifier="nibPopup">
                    <rect key="frame" x="296" y="78" width="140" height="26"/>
                    <autoresizingMask key="autoresizingMask" flexibleMinY="YES"/>
                    <popUpButtonCell key="cell" type="push" title="Cocoa" bezelStyle="rounded" alignment="left" lineBreakMode="truncatingTail" borderStyle="borderAndBezel" inset="2" selectedItem="pit-2" id="pop-1c">
                        <behavior key="behavior" lightByBackground="YES" lightByGray="YES"/>
                        <font key="font" metaFont="menu"/>
                        <menu key="menu" id="mnu-1">
                            <items>
                                <menuItem title="Carbon" id="pit-1"/>
                                <menuItem title="Cocoa" state="on" id="pit-2"/>
                                <menuItem title="Chocolate" id="pit-3"/>
                            </items>
                        </menu>
                    </popUpButtonCell>
                </popUpButton>
                <box fixedFrame="YES" title="From the xib" translatesAutoresizingMaskIntoConstraints="NO" id="box-1" identifier="nibBox">
                    <rect key="frame" x="18" y="14" width="446" height="52"/>
                    <autoresizingMask key="autoresizingMask" flexibleMaxY="YES"/>
                </box>
            </subviews>
        </customView>
    </objects>
</document>
